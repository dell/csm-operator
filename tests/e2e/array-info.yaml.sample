#
# E2E test array configuration.
#
# Sections: <platform> or <platform>-<feature>
# Platforms: powerflex, powerscale, powermax, powerstore, unity, cosi
# Features:  auth, zoning, replication, oidc, sftp
#
# Filtering rules:
#   - "global" always loads (namespace prefix, shared settings).
#   - Base sections (e.g. "powerflex") load when the platform is selected.
#   - Feature sections (e.g. "powerflex-auth") load when BOTH the platform
#     AND the feature are active. --no-modules disables all features.
#   - "common" loads only when auth is active (Conjur/Redis credentials).
#
# Within each section, only non-empty values are exported.
# To configure a field: replace "" with the real value.
# The comment after each field shows an example value.

# -- Global --
global:
  NS_PREFIX: "e2e"             # namespace prefix for all E2E namespaces

# -- Common Authorization (Redis / JWT config shared across all platforms) --
auth-common:
  REDIS_USER: ""           # user
  REDIS_PASS: ""           # pass
  JWT_SIGNING_SECRET: ""   # "web:\n  jwtsigningsecret: secret"

# -- PowerFlex --
powerflex:
  POWERFLEX_USER: ""           # admin
  POWERFLEX_PASS: ""           # Password123!
  POWERFLEX_SYSTEMID: ""       # 260e3a704877200f
  POWERFLEX_ENDPOINT: ""       # 10.1.1.1 (do not include https://)
  POWERFLEX_MDM: ""            # 10.0.0.1,10.0.0.2
  POWERFLEX_NAS: ""            # none
  POWERFLEX_PROTOCOL: "auto"   # auto
  POWERFLEX_POOL: ""           # pool1

powerflex-auth:
  POWERFLEX_AUTH_ENDPOINT: ""          # localhost:9401
  POWERFLEX_STORAGE: ""                # powerflex
  POWERFLEX_VAULT_STORAGE_PATH: ""    # storage/powerflex
  POWERFLEX_QUOTA: ""                  # 10GiB
  POWERFLEX_ROLE: ""                   # csmrole-powerflex
  POWERFLEX_TENANT: ""                 # csmtenant-powerflex
  POWERFLEX_TENANT_PREFIX: ""          # tn1

powerflex-zoning:
  POWERFLEX_ZONING_USER: ""           # zoningUsername
  POWERFLEX_ZONING_PASS: ""           # zoningPassword
  POWERFLEX_ZONING_SYSTEMID: ""       # zoningSystemID
  POWERFLEX_ZONING_ENDPOINT: ""       # 10.1.1.2
  POWERFLEX_ZONING_MDM: ""            # 10.0.0.3,10.0.0.4
  POWERFLEX_ZONING_NAS: ""            # none
  POWERFLEX_ZONING_POOL: ""           # pool1

powerflex-oidc:
  POWERFLEX_OIDC_CLIENTID: ""         # oidcClientID
  POWERFLEX_OIDC_CLIENT_SECRET: ""    # oidcClientSecret
  POWERFLEX_CIAM_CLIENTID: ""         # ciamClientID
  POWERFLEX_CIAM_CLIENT_SECRET: ""    # ciamClientSecret
  POWERFLEX_ISSUER: ""                 # https://login.microsoftonline.com/abcd/v2.0
  POWERFLEX_SCOPE: ""                  # openid,profile,email

powerflex-sftp:
  POWERFLEX_SDC_SFTP_REPO_ENABLED: ""   # false
  POWERFLEX_SFTP_REPO_ADDRESS: ""       # sftp://0.0.0.0
  POWERFLEX_SFTP_REPO_USER: ""          # sdcRepoUser

# -- PowerScale --
powerscale:
  POWERSCALE_CLUSTER: ""       # Isilon-System-Name
  POWERSCALE_USER: ""          # root
  POWERSCALE_PASS: ""          # Password123!
  POWERSCALE_ENDPOINT: ""      # 1.1.1.1 (do not include https://)
  POWERSCALE_PORT: ""          # 8080

powerscale-auth:
  POWERSCALE_AUTH_ENDPOINT: ""         # localhost
  POWERSCALE_AUTH_PORT: ""             # 9400
  POWERSCALE_POOL_V1: ""              # ifs/data/csi
  POWERSCALE_POOL_V2: ""              # /ifs/data/csi
  POWERSCALE_STORAGE: ""               # powerscale
  POWERSCALE_VAULT_STORAGE_PATH: ""   # storage/powerscale
  POWERSCALE_QUOTA: ""                 # 0GB
  POWERSCALE_ROLE: ""                  # csmrole-powerscale
  POWERSCALE_TENANT: ""                # csmtenant-powerscale
  POWERSCALE_TENANT_PREFIX: ""         # tn1

powerscale-replication:
  POWERSCALE_MULTI_CLUSTER: ""        # Isilon-System-Name
  POWERSCALE_MULTI_USER: ""           # root
  POWERSCALE_MULTI_PASS: ""           # Password123!
  POWERSCALE_MULTI_ENDPOINT: ""       # 1.1.1.1
  POWERSCALE_MULTI_PORT: ""           # 8080
  POWERSCALE_MULTI_AUTH_ENDPOINT: ""  # localhost
  POWERSCALE_MULTI_AUTH_PORT: ""      # 9400

# -- PowerMax --
powermax:
  POWERMAX_SYSTEMID: ""        # 000120001647
  POWERMAX_ENDPOINT: ""        # 10.0.0.1:8443
  POWERMAX_USER: ""            # username
  POWERMAX_PASS: ""            # password
  POWERMAX_USER_ENCODED: ""    # base64-encoded username
  POWERMAX_PASS_ENCODED: ""    # base64-encoded password
  POWERMAX_SERVICE_LEVEL: ""   # Bronze
  POWERMAX_PORTGROUPS: ""      # (can be left empty)
  POWERMAX_PROTOCOL: ""        # (can be left empty)
  POWERMAX_ARRAYS: ""          # 000000000000,000000000001
  POWERMAX_POOL_V1: ""         # SRP_1
  POWERMAX_POOL_V2: ""         # SRP_2

powermax-auth:
  POWERMAX_AUTH_ENDPOINT: ""   # localhost:9400
  POWERMAX_STORAGE: ""         # powermax
  POWERMAX_VAULT_STORAGE_PATH: ""     # storage/powermax
  POWERMAX_QUOTA: ""                   # 0GiB
  POWERMAX_ROLE: ""                    # csmrole-powermax
  POWERMAX_TENANT: ""                  # csmtenant-powermax
  POWERMAX_TENANT_PREFIX: ""           # tn1

powermax-zoning:
  POWERMAX_ZONING_USER: ""            # zoningUsername
  POWERMAX_ZONING_PASS: ""            # zoningPassword
  POWERMAX_ZONING_SYSTEMID: ""        # zoningSystemID
  POWERMAX_ZONING_ENDPOINT: ""        # 10.1.1.2

# -- PowerStore --
powerstore:
  POWERSTORE_USER: ""          # username
  POWERSTORE_PASS: ""          # password
  POWERSTORE_GLOBALID: ""      # myglobalpowerstoreid
  POWERSTORE_ENDPOINT: ""      # 1.1.1.1 (ip only, no /api/rest)
  POWERSTORE_PROTOCOL: "auto"  # auto

powerstore-auth:
  POWERSTORE_AUTH_ENDPOINT: ""         # 127.0.0.1:9400
  POWERSTORE_STORAGE: ""               # powerstore
  POWERSTORE_VAULT_STORAGE_PATH: ""   # storage/powerstore
  POWERSTORE_QUOTA: ""                 # 0GiB
  POWERSTORE_ROLE: ""                  # csmrole-powerstore
  POWERSTORE_TENANT: ""                # csmtenant-powerstore
  POWERSTORE_TENANT_PREFIX: ""         # tn1
  POWERSTORE_POOL: ""                  # myglobalpowerstoreid

# -- Unity --
unity:
  UNITY_USER: ""           # username
  UNITY_PASS: ""           # password
  UNITY_ARRAYID: ""        # myglobalunityid
  UNITY_ENDPOINT: ""       # 1.1.1.1
  UNITY_NAS: ""            # mynas
  UNITY_POOL: ""           # mypool

# -- COSI --
cosi:
  COSI_USER: ""            # username
  COSI_PASS: ""            # password
  COSI_NAMESPACE: ""       # namespace
  COSI_MGMT_ENDPOINT: ""  # https://address:port
  COSI_S3_ENDPOINT: ""    # https://address:port
